# Select all columns except Depth and DistanceLand
cols_to_consider <- setdiff(colnames(env4), c("Depth", "DistanceLand"))
# Select all columns except Depth and DistanceLand
cols_to_consider <- setdiff(colnames(env4_df), c("Depth", "DistanceLand"))
